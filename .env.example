# Copy to .env: cp .env.example .env

# ── Admin credentials ─────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# Set a strong password. If left unset in local dev, a random one is generated
# on first start and printed once in the server logs.
ADMIN_PASSWORD=

# ── Security (required) ───────────────────────────────────────────────────────
# Min 32 characters. The app refuses to start without this.
# Generate one with: openssl rand -hex 32
JWT_SECRET=

# ── User registration ─────────────────────────────────────────────────────────
# Only emails ending in this domain can register (e.g. mycompany.com).
# Leave empty to disable self-registration entirely.
ALLOWED_DOMAIN=

# ── Media search in Quiz Studio (optional) ────────────────────────────────────
# API keys stay server-side. Openverse works without keys; missing keys hide
# that provider's tab in the media picker.
UNSPLASH_ACCESS_KEY=
GIPHY_API_KEY=

# ── Docker / Caddy only (optional) ────────────────────────────────────────────
# Set your domain for automatic HTTPS via Let's Encrypt. Leave unset for HTTP :80.
# DOMAIN=quiz.example.com
