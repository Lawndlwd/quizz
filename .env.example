# ── Admin credentials ─────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# Set a strong password. If left unset, the app generates a random one on first
# run and prints it to the server logs once — log in and change it immediately.
ADMIN_PASSWORD=

# ── App branding ───────────────────────────────────────────────────────────────
# Shown as "<APP_NAME> by ⚡ Quizz" — leave empty to show just "⚡ Quizz"
APP_NAME=

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED. The app refuses to start without a strong secret (min 32 chars).
# Generate one with: openssl rand -hex 32
JWT_SECRET=

# ── User registration ─────────────────────────────────────────────────────────
# Only emails ending in this domain can register (e.g. scaleway.com).
# Leave empty to disable self-registration entirely.
ALLOWED_DOMAIN=

# ── SMTP (reserved for future email features) ─────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# ── Caddy domain (optional) ───────────────────────────────────────────────────
# Leave empty to run on plain HTTP :80
# Set to your domain to get automatic HTTPS via Let's Encrypt
# DOMAIN=quiz.example.com
